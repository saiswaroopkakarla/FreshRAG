# ============================================================
# FreshRAG configuration
# Copy this file to ".env" and fill in whatever you have.
# The system runs with ZERO keys using free/local fallbacks:
#   - Query understanding -> rule-based keyword analyzer (no key needed)
#   - Web search  -> DuckDuckGo (no key needed)
#   - Embeddings  -> TF-IDF (no key needed, no model download)
#   - Answer gen  -> Extractive summarizer (no key needed)
# Add API keys below only to upgrade any of those components.
# ============================================================

# --- Query understanding (recommended upgrade) ---
# A fixed keyword table can't reliably classify open-domain queries or
# tolerate typos. Add ANY ONE of these keys to switch query
# understanding to an LLM instead -- it reasons about arbitrary topics
# and produces the ranking weights directly, per query.
# Priority if multiple are set: Groq -> DeepSeek -> OpenAI -> Anthropic.
#
# Groq: https://console.groq.com -- genuinely free tier, very fast, recommended default.
GROQ_API_KEY=
# DeepSeek: https://platform.deepseek.com -- cheap, OpenAI-compatible.
DEEPSEEK_API_KEY=

# --- Search providers (optional) ---
# If NEWSAPI_KEY is set, FreshRAG will also query NewsAPI.org for
# time-sensitive / news-domain queries, in addition to DuckDuckGo.
NEWSAPI_KEY=

# If TAVILY_API_KEY is set, Tavily will be used as an additional
# search source (good recall for research-y queries).
TAVILY_API_KEY=

# --- LLM answer generation (optional, tried in this priority order) ---
# Anthropic -> OpenAI -> Groq -> DeepSeek -> built-in extractive fallback.
# Anthropic/OpenAI are tried first since paying for one usually signals
# you want its synthesis quality; Groq/DeepSeek give a real synthesized,
# cited answer for free/cheap if that's all you have configured. Any ONE
# of these four is enough -- you don't need to set all of them.
# (These are the SAME keys as the query-understanding section above --
# one key configured there is automatically usable here too.)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Query understanding mode ---
# auto (default): use an LLM if any key above is configured, else
#   rule-based. llm: force LLM (errors if no key). rule-based: always
#   use the keyword-table analyzer even if a key is set -- useful for
#   an A/B ablation between the two approaches.
QUERY_UNDERSTANDING_MODE=auto

# --- Embeddings ---
# tfidf (default, free, instant) | sentence-transformers (semantic, needs extra pip install)
EMBEDDING_MODE=tfidf

# --- Freshness decay function ---
# exponential (default) | linear | logistic | piecewise
FRESHNESS_DECAY=exponential

# --- Retrieval / ranking tuning ---
TOP_K_RESULTS=8
MAX_URLS_TO_FETCH=10
CHUNK_SIZE_WORDS=220
CHUNK_OVERLAP_WORDS=40

# --- Backend location (used by the Streamlit frontend) ---
BACKEND_URL=http://localhost:8000
